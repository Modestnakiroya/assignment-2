        "def build_effdet_target(boxes, labels, device, img_size=512):\n",
        "    batch_size = len(boxes)\n",
        "    max_boxes  = max(\n",
        "        b.shape[0] if b.shape[0] > 0 else 1\n",
        "        for b in boxes\n",
        "    )\n",
        "    bbox_batch = torch.zeros(\n",
        "        (batch_size, max_boxes, 4),\n",
        "        dtype=torch.float32, device=device\n",
        "    )\n",
        "    cls_batch  = torch.zeros(\n",
        "        (batch_size, max_boxes),\n",
        "        dtype=torch.float32, device=device\n",
        "    )\n",
        "    for i in range(batch_size):\n",
        "        bx = boxes[i].to(device)\n",
        "        lb = labels[i].to(device).float()\n",
        "        n  = bx.shape[0]\n",
        "        if n > 0:\n",
        "            bbox_batch[i, :n] = bx\n",
        "            cls_batch[i,  :n] = lb\n",
        "    return {\n",
        "        \"bbox\":      bbox_batch,\n",
        "        \"cls\":       cls_batch,\n",
        "        \"img_size\":  torch.tensor(\n",
        "            [[img_size, img_size]] * batch_size,\n",
        "            dtype=torch.float32, device=device\n",
        "        ),\n",
        "        \"img_scale\": torch.ones(\n",
        "            batch_size,\n",
        "            dtype=torch.float32, device=device\n",
        "        )\n",
        "    }\n",
        "\n",
        "print(\"✅ Target helper ready\")"
