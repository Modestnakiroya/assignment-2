        "import torchvision.transforms as T\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "\n",
        "class EfficientDetDataset(Dataset):\n",
        "    def __init__(self, img_dir, class_list, img_size=512):\n",
        "        self.img_dir    = img_dir\n",
        "        self.class_list = class_list\n",
        "        self.img_size   = img_size\n",
        "        self.transforms = T.Compose([\n",
        "            T.Resize((img_size, img_size)),\n",
        "            T.ToTensor(),\n",
        "            T.Normalize(\n",
        "                mean=[0.485, 0.456, 0.406],\n",
        "                std=[0.229, 0.224, 0.225]\n",
        "            )\n",
        "        ])\n",
        "        self.samples = []\n",
        "        for f in os.listdir(img_dir):\n",
        "            if f.endswith((\".jpg\", \".jpeg\", \".png\")):\n",
        "                stem     = os.path.splitext(f)[0]\n",
        "                xml_path = os.path.join(img_dir, stem + \".xml\")\n",
        "                if os.path.exists(xml_path):\n",
        "                    self.samples.append((f, xml_path))\n",
        "        print(f\"Found {len(self.samples)} samples in {img_dir}\")\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.samples)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        img_file, xml_path = self.samples[idx]\n",
        "        image    = Image.open(\n",
        "            os.path.join(self.img_dir, img_file)\n",
        "        ).convert(\"RGB\")\n",
        "        orig_w, orig_h = image.size\n",
        "\n",
        "        tree  = ET.parse(xml_path)\n",
        "        root  = tree.getroot()\n",
        "        boxes, labels = [], []\n",
        "\n",
        "        for obj in root.findall(\"object\"):\n",
        "            cls = obj.find(\"name\").text\n",
        "            if cls not in self.class_list:\n",
        "                continue\n",
        "            b    = obj.find(\"bndbox\")\n",
        "            xmin = int(b.find(\"xmin\").text) / orig_w * self.img_size\n",
        "            ymin = int(b.find(\"ymin\").text) / orig_h * self.img_size\n",
        "            xmax = int(b.find(\"xmax\").text) / orig_w * self.img_size\n",
        "            ymax = int(b.find(\"ymax\").text) / orig_h * self.img_size\n",
        "            xmin = max(0, min(xmin, self.img_size))\n",
        "            ymin = max(0, min(ymin, self.img_size))\n",
        "            xmax = max(0, min(xmax, self.img_size))\n",
        "            ymax = max(0, min(ymax, self.img_size))\n",
        "            if xmax > xmin and ymax > ymin:\n",
        "                boxes.append([xmin, ymin, xmax, ymax])\n",
        "                labels.append(self.class_list.index(cls) + 1)\n",
        "\n",
        "        if len(boxes) == 0:\n",
        "            boxes  = torch.zeros((0, 4), dtype=torch.float32)\n",
        "            labels = torch.zeros((0,),   dtype=torch.long)\n",
        "        else:\n",
        "            boxes  = torch.tensor(boxes,  dtype=torch.float32)\n",
        "            labels = torch.tensor(labels, dtype=torch.long)\n",
        "\n",
        "        return self.transforms(image), {\n",
        "            \"boxes\": boxes, \"labels\": labels\n",
        "        }\n",
        "\n",
        "\n",
        "def collate_fn(batch):\n",
        "    images  = torch.stack([item[0] for item in batch])\n",
        "    targets = [item[1] for item in batch]\n",
        "    return images, targets\n",
        "\n",
        "\n",
        "train_dataset = EfficientDetDataset(TRAIN_DIR, class_list)\n",
        "valid_dataset = EfficientDetDataset(VALID_DIR, class_list)\n",
        "\n",
        "train_loader  = DataLoader(\n",
        "    train_dataset, batch_size=8, shuffle=True,\n",
        "    collate_fn=collate_fn, num_workers=2,\n",
        "    pin_memory=True\n",
        ")\n",
        "valid_loader  = DataLoader(\n",
        "    valid_dataset, batch_size=8, shuffle=False,\n",
        "    collate_fn=collate_fn, num_workers=2,\n",
        "    pin_memory=True\n",
        ")\n",
        "\n",
        "print(f\"Train batches: {len(train_loader)}\")\n",
